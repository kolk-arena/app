#!/usr/bin/env bash
#
# Kolk commit-msg hook — reject delegated-credit signatures.
#
# Public-history policy: delegated-credit and generated-content footers must
# not enter git history.
#
# Enable: git config core.hooksPath .githooks
#         (already baked into CONTRIBUTING.md onboarding)
#
# Bypass (strongly discouraged): git commit --no-verify
#         If you need to bypass, relax the rule in §2 first, not by silent
#         exception.

set -eu

msg_file="${1:-.git/COMMIT_EDITMSG}"

if [ ! -f "$msg_file" ]; then
  # Called without a message file (unlikely from git directly). Nothing to
  # check.
  exit 0
fi

# Build these strings in pieces so public text scans do not see example
# trailers as if they were real commit metadata.
co_trailer='Co-Authored''-By'
sign_trailer='Signed''-off-by'
gen_trailer='Generated''-by'

# 1. Reject delegated-credit trailers outright.
if grep -qiE "^(${co_trailer}|${sign_trailer}|${gen_trailer}):" "$msg_file"; then
  echo "ERROR: forbidden delegated-credit trailer in commit message." >&2
  echo "       Remove delegated-credit footer lines" >&2
  echo "       and retry. This repo keeps public commit history free of" >&2
  echo "       delegated-credit trailers." >&2
  echo "" >&2
  echo "       Policy: public-history commit hygiene." >&2
  exit 1
fi

# 2. Reject generated-by footer lines.
if grep -qiE '🤖[[:space:]]*Generated with[[:space:]]+[^[:space:]]+' "$msg_file"; then
  echo "ERROR: AI generation footer rejected." >&2
  echo "       Remove the '🤖 Generated with …' line and retry." >&2
  echo "" >&2
  echo "       Policy: public-history commit hygiene." >&2
  exit 1
fi

exit 0
