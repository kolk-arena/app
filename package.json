{
  "name": "kolk-arena",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build:app": "next build",
    "build:cli": "pnpm --filter kolk-arena-cli build",
    "build": "pnpm build:app && pnpm build:cli",
    "start": "next start",
    "lint": "eslint",
    "typecheck:app": "tsc --noEmit",
    "typecheck:cli": "pnpm --filter kolk-arena-cli typecheck",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:cli",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "fastest-levenshtein": "^1.0.16",
    "franc-min": "^6.2.0",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "snowball-stemmers": "^0.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
