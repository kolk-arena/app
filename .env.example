# ============================================================================
# Kolk Arena — environment variables template
# ============================================================================
#
# Copy to .env.local for local dev, or paste each key into the Vercel
# project's Environment Variables UI for production.
#
# NEXT_PUBLIC_* values ship into the browser bundle. Everything else is
# server-only. Never commit real values. Keep the full operator checklist in
# your private runbook, not in the public repo.
# ============================================================================

# --- Application origin -----------------------------------------------------
# Full HTTPS origin the app serves from. Used by the device flow to build
# the verification_uri shown to CLIs (e.g. https://www.kolkarena.com/device).
# In production this must be the canonical public host exactly.
# Local dev may override this in `.env.local` with `http://localhost:3000`.
NEXT_PUBLIC_APP_URL=https://www.kolkarena.com

# Public browser auth switches. Keep these at 0 unless the corresponding
# Supabase provider is fully configured and tested end-to-end.
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=0
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=0

# --- Supabase (required) ---------------------------------------------------
# From the Supabase project's API settings. Note the KOLK_ prefix — the
# repo does NOT use the default SUPABASE_* names.
KOLK_SUPABASE_URL=https://your-project.supabase.co
KOLK_SUPABASE_ANON_KEY=your-anon-key

# KEEP SECRET. Bypasses RLS. Never exposed to the browser. Never log.
KOLK_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI provider credentials (operator-only) ---------------------------------
# These are the platform-side credentials used to generate challenges and
# score submissions. Public-beta players do NOT supply these keys.
#
# Freeze these names now. The beta launch routing stack is multi-provider:
# - xAI / Grok
# - OpenAI / GPT-5 Nano + GPT-5 Mini
# - Gemini / Google AI
#
# L0 onboarding is deterministic and does not use any provider.
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=gemini-...

# Optional compatibility overrides for the xAI-backed code paths.
# Leave unset to use the defaults baked into src/lib/kolk/evaluator/judge.ts.
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-non-reasoning

# Optional model overrides for runtime consumers that read
# src/lib/kolk/ai/runtime.ts (for example the ChallengeBrief Preview
# generator). The judged submit path pins its own scoring models in
# src/lib/kolk/evaluator/judge.ts, so these are not the public scoring
# contract knobs.
# OPENAI_MODEL=gpt-5-mini
# GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of provider-combo keys to disable at runtime. Read by
# src/lib/kolk/ai/runtime.ts:366. Leave unset to enable all combos.
# KOLK_DISABLE_COMBOS=

# --- Operator-only admin surface --------------------------------------------
# Pick a long random string (40+ chars). Rotate by updating both the env
# var and anyone who holds the value.
KOLK_ADMIN_SECRET=your-admin-secret

# --- Email (reserved for future email OTP sign-in; not currently wired) -----
# As of 2026-04-23 there are 0 `RESEND` references in src/. These keys are
# aspirational placeholders for when the email OTP path is implemented; the
# running app does not read them. Kept so operators don't have to re-derive
# the variable names once the feature lands.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@kolkarena.com

# --- ChallengeBrief Preview -------------------------------------------------
# Set to "1" to enable the synthetic ChallengeBrief preview carousel.
KOLK_BRIEF_SHOWCASE_ENABLED=0
# Comma-separated extra locale codes. English is always generated. Leave
# blank unless you have a locale-aware surface that will actually request
# those translations.
KOLK_BRIEF_SHOWCASE_EXTRA_LOCALES=
# Batch expiry / dedup TTL in minutes (default: 60). The public homepage
# route hides expired batches; changing this alone does NOT change the
# scheduler cadence in vercel.json.
KOLK_BRIEF_SHOWCASE_REFRESH_MINUTES=60
# AI provider used for generation: "xai" | "openai" | "gemini"
KOLK_BRIEF_SHOWCASE_PROVIDER=xai
# Model override (optional; falls back to provider default). If you use
# `openai`, prefer a compatible non-reasoning model or leave the provider
# on `xai` / `gemini`.
# KOLK_BRIEF_SHOWCASE_MODEL=

# --- Vercel Cron authorization -----------------------------------------------
# Vercel Cron auto-sends `Authorization: Bearer $CRON_SECRET`, so this exact
# name is the one to set in Vercel for `/api/internal/cron/brief-showcase`.
CRON_SECRET=your-cron-secret

# --- CLI env overrides (packages/kolk-arena-cli) ----------------------------
# These are for local CLI testing or CI runs that do not go through
# `kolk-arena login`. Not set on the server.
# KOLK_TOKEN=kat_...
# KOLK_ARENA_URL=https://www.kolkarena.com
# KOLK_ARENA_CONFIG_DIR=~/.config/kolk-arena
