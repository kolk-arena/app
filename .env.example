# ============================================================================
# Kolk Arena — Environment Variables
# Copy to .env.local and fill in values
# ============================================================================

# --- Supabase ---
KOLK_SUPABASE_URL=https://your-project.supabase.co
KOLK_SUPABASE_ANON_KEY=your-anon-key
KOLK_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Model ---
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-non-reasoning

# --- Email (optional) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@kolkarena.com

# --- Admin ---
KOLK_ADMIN_SECRET=your-admin-secret

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
